<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <title>map, filter e reduce</title>
</head>
<body>

<h2>Abra o console (F12)</h2>

<script>
const produtos = [
  { nome: "Mouse",    preco: 80,  estoque: 5  },
  { nome: "Teclado",  preco: 150, estoque: 0  },
  { nome: "Monitor",  preco: 900, estoque: 2  },
  { nome: "Headset",  preco: 200, estoque: 8  },
  { nome: "Webcam",   preco: 120, estoque: 0  },
];

// 🔹 FILTER → produtos com estoque > 0
const disponiveis = produtos.filter(p => p.estoque > 0);
console.log("Disponíveis:", disponiveis);

// 🔹 MAP → aplicar 10% de desconto
const comDesconto = produtos.map(p => ({
  nome: p.nome,
  preco: p.preco * 0.9
}));
console.log("Com desconto:", comDesconto);

// 🔹 REDUCE → valor total do estoque
const totalEstoque = produtos.reduce((total, p) => {
  return total + (p.preco * p.estoque);
}, 0);
console.log("Valor total do estoque:", totalEstoque);

// 🔹 DESAFIO → apenas produtos disponíveis
const totalDisponiveis = produtos
  .filter(p => p.estoque > 0)
  .reduce((total, p) => total + (p.preco * p.estoque), 0);

console.log("Total (apenas disponíveis):", totalDisponiveis);

</script>

</body>
</html>